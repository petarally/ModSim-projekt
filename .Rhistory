# Veličina efekta — Cohenov d
d <- (mean(place) - mu0) / sd(place)
cat("Cohenov d:", round(d, 4), "\n")
cat("Interpretacija: |d| <0.2 = zanemariv, 0.2–0.5 = mali, 0.5–0.8 = srednji, >0.8 = veliki\n")
# Neparametarska alternativa (Wilcoxonov jednouzorački test)
wilcox.test(place, mu = mu0, alternative = "two.sided", conf.level = 0.95)
alpha <- 0.05
if (rezultat$p.value < alpha) {
cat("p =", round(rezultat$p.value, 6), "< α =", alpha, "\n")
cat("Odluka: ODBACUJEMO nul hipotezu H₀.\n")
} else {
cat("p =", round(rezultat$p.value, 6), ">= α =", alpha, "\n")
cat("Odluka: NE ODBACUJEMO nul hipotezu H₀.\n")
}
b0 <- round(coef(model)[1], 4)
b1 <- round(coef(model)[2], 4)
R2 <- round(summary(model)$r.squared, 4)
R2_adj <- round(summary(model)$adj.r.squared, 4)
cat("Jednadžba modela:\n")
cat("  broj_dovrsenih_zadataka =", b0, "+", b1, "× sati_fokusiranog_rada\n\n")
cat("R² =", R2, "\n")
cat("Prilagođeni R² =", R2_adj, "\n")
# Pearsonov koeficijent korelacije
kor <- cor.test(X, Y, method = "pearson")
print(kor)
cat("\nPearsonov r:", round(kor$estimate, 4), "\n")
cat("95% CI: [", round(kor$conf.int[1], 4), ",", round(kor$conf.int[2], 4), "]\n")
cat("p-vrijednost:", format.pval(kor$p.value, digits = 4), "\n")
b0 <- round(coef(model)[1], 4)
b1 <- round(coef(model)[2], 4)
R2 <- round(summary(model)$r.squared, 4)
R2_adj <- round(summary(model)$adj.r.squared, 4)
cat("Jednadžba modela:\n")
cat("  broj_dovrsenih_zadataka =", b0, "+", b1, "× sati_fokusiranog_rada\n\n")
cat("R² =", R2, "\n")
cat("Prilagođeni R² =", R2_adj, "\n")
x_seq <- seq(min(X), max(X), length.out = 200)
pred  <- predict(model,
newdata = data.frame(sati_fokusiranog_rada = x_seq),
interval = "confidence")
plot(X, Y,
main = "Regresijski model: fokusirani rad → dovršeni zadaci",
xlab = "Sati fokusiranog rada (h/dan)",
ylab = "Broj dovršenih zadataka",
pch  = 16,
col  = "#2C7BB666",
cex  = 1.1)
polygon(c(x_seq, rev(x_seq)),
c(pred[,"lwr"], rev(pred[,"upr"])),
col = "#FF000022", border = NA)
str(df_clean)
knitr::opts_chunk$set(echo = TRUE)
