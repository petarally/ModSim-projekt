# ============================================================
#  Jednostavni SIR Model
#  S = Susceptible (osjetljivi)
#  I = Infected (zaraženi)
#  R = Recovered (oporavljeni)
# ============================================================
# Instaliraj paket ako nije instaliran
if (!requireNamespace("deSolve", quietly = TRUE)) {
install.packages("deSolve")
}
library(deSolve)
# ------------------------------------------------------------
# 1. Definicija diferencijalnih jednadžbi SIR modela
# ------------------------------------------------------------
sir_model <- function(time, state, parameters) {
with(as.list(c(state, parameters)), {
N <- S + I + R          # ukupna populacija
dS <- -beta * S * I / N
dI <-  beta * S * I / N - gamma * I
dR <-  gamma * I
list(c(dS, dI, dR))
})
}
# ------------------------------------------------------------
# 2. Parametri modela
# ------------------------------------------------------------
parameters <- c(
beta  = 0.3,   # stopa prijenosa (kontakti × vjerojatnost zaraze)
gamma = 0.05   # stopa oporavka (1/gamma = prosječno trajanje bolesti u danima)
)
# R0 = basic reproduction number
R0 <- parameters["beta"] / parameters["gamma"]
cat(sprintf("Osnovni reprodukcijski broj R0 = %.2f\n", R0))
# ------------------------------------------------------------
# 3. Početni uvjeti
# ------------------------------------------------------------
N         <- 10000   # ukupna populacija
I0        <- 10      # početni broj zaraženih
R0_init   <- 0       # početni broj oporavljenih
S0        <- N - I0 - R0_init
state <- c(S = S0, I = I0, R = R0_init)
# ------------------------------------------------------------
# 4. Vremenska os (dani)
# ------------------------------------------------------------
times <- seq(0, 365, by = 1)
# ------------------------------------------------------------
# 5. Rješavanje sustava ODE
# ------------------------------------------------------------
solution <- as.data.frame(
ode(y = state, times = times, func = sir_model, parms = parameters)
)
# Pregled prvih nekoliko redaka
cat("\nPrvih 6 redaka rezultata:\n")
print(head(solution))
# Vrhunac epidemije
peak_day <- solution$time[which.max(solution$I)]
peak_I   <- max(solution$I)
cat(sprintf("\nVrhunac epidemije: dan %d, zaraženih %.0f (%.1f%% populacije)\n",
peak_day, peak_I, peak_I / N * 100))
# Konačni broj zaraženih (ukupno kroz cijelu epidemiju)
final_R <- tail(solution$R, 1)
cat(sprintf("Ukupno je zaraženo: %.0f osoba (%.1f%% populacije)\n",
final_R, final_R / N * 100))
# ------------------------------------------------------------
# 6. Vizualizacija
# ------------------------------------------------------------
plot(solution$time, solution$S,
type = "l", col = "steelblue", lwd = 2.5,
ylim = c(0, N),
xlab = "Dani", ylab = "Broj osoba",
main = sprintf("SIR Model  (β=%.2f, γ=%.2f, R0=%.1f)",
parameters["beta"], parameters["gamma"], R0))
lines(solution$time, solution$I, col = "firebrick", lwd = 2.5)
lines(solution$time, solution$R, col = "forestgreen", lwd = 2.5)
abline(v = peak_day, lty = 2, col = "grey50")
legend("right",
legend = c("Osjetljivi (S)", "Zaraženi (I)", "Oporavljeni (R)"),
col    = c("steelblue", "firebrick", "forestgreen"),
lwd    = 2.5, bty = "n")
# ============================================================
#  SIRD Model (prošireni SIR smrtnošću)
#  S = Susceptible  (osjetljivi)
#  I = Infected     (zaraženi)
#  R = Recovered    (oporavljeni)
#  D = Dead         (preminuli)
# ============================================================
if (!requireNamespace("deSolve", quietly = TRUE)) {
install.packages("deSolve")
}
library(deSolve)
# ------------------------------------------------------------
# 1. Diferencijalne jednadžbe SIRD modela
# ------------------------------------------------------------
sird_model <- function(time, state, parameters) {
with(as.list(c(state, parameters)), {
N <- S + I + R   # živuća populacija (D se ne ubraja)
dS <- -beta  * S * I / N
dI <-  beta  * S * I / N - gamma * I - mu * I
dR <-  gamma * I
dD <-  mu    * I
list(c(dS, dI, dR, dD))
})
}
# ------------------------------------------------------------
# 2. Parametri modela
# ------------------------------------------------------------
parameters <- c(
beta  = 0.3,    # stopa prijenosa
gamma = 0.05,   # stopa oporavka  (≈ 20 dana bolesti)
mu    = 0.005   # stopa smrtnosti od bolesti (CFR ≈ mu/(mu+gamma) = ~9%)
)
CFR <- parameters["mu"] / (parameters["mu"] + parameters["gamma"]) * 100
R0  <- parameters["beta"] / (parameters["gamma"] + parameters["mu"])
cat(sprintf("Osnovni reprodukcijski broj  R0  = %.2f\n", R0))
cat(sprintf("Stopa smrtnosti slučajeva   CFR  = %.1f%%\n", CFR))
# ------------------------------------------------------------
# 3. Početni uvjeti
# ------------------------------------------------------------
N      <- 10000
I0     <- 10
state  <- c(S = N - I0, I = I0, R = 0, D = 0)
# ------------------------------------------------------------
# 4. Vremenska os (dani)
# ------------------------------------------------------------
times <- seq(0, 365, by = 1)
# ------------------------------------------------------------
# 5. Numeričko rješavanje
# ------------------------------------------------------------
solution <- as.data.frame(
ode(y = state, times = times, func = sird_model, parms = parameters)
)
# Provjera konzervacije: S+I+R+D mora uvijek biti = N
stopifnot(all(abs(rowSums(solution[, c("S","I","R","D")]) - N) < 1e-6))
# Statistike
peak_day <- solution$time[which.max(solution$I)]
peak_I   <- max(solution$I)
final_D  <- tail(solution$D, 1)
final_R  <- tail(solution$R, 1)
cat(sprintf("\nVrhunac epidemije : dan %d,  zaraženih %.0f (%.1f%% populacije)\n",
peak_day, peak_I, peak_I / N * 100))
cat(sprintf("Ukupno preminulo  : %.0f osoba (%.1f%% populacije)\n",
final_D, final_D / N * 100))
cat(sprintf("Ukupno oporavilo  : %.0f osoba (%.1f%% populacije)\n",
final_R, final_R / N * 100))
cat("\nPrvih 6 redaka rezultata:\n")
print(head(round(solution, 1)))
# ------------------------------------------------------------
# 6. Vizualizacija
# ------------------------------------------------------------
par(mar = c(5, 4, 4, 2))
plot(solution$time, solution$S,
type = "l", col = "steelblue", lwd = 2.5,
ylim = c(0, N),
xlab = "Dani", ylab = "Broj osoba",
main = sprintf("SIRD Model  (β=%.2f, γ=%.3f, μ=%.3f | R0=%.1f, CFR=%.1f%%)",
parameters["beta"], parameters["gamma"],
parameters["mu"], R0, CFR))
lines(solution$time, solution$I, col = "firebrick",   lwd = 2.5)
lines(solution$time, solution$R, col = "forestgreen", lwd = 2.5)
lines(solution$time, solution$D, col = "grey20",      lwd = 2.5, lty = 2)
abline(v = peak_day, lty = 3, col = "grey60")
legend("right",
legend = c("Osjetljivi (S)", "Zaraženi (I)",
"Oporavljeni (R)", "Preminuli (D)"),
col    = c("steelblue", "firebrick", "forestgreen", "grey20"),
lty    = c(1, 1, 1, 2),
lwd    = 2.5, bty = "n")
# ============================================================
#  SIR Model – COVID-19 u Hrvatskoj
#
#  Podaci preuzeti s:
#    https://www.worldometers.info/coronavirus/#countries
#    https://www.worldometers.info/coronavirus/country/croatia/
#
#  Zemlja        : Hrvatska (Croatia)
#  Populacija    : 3,826,630  (Worldometers, zadnja kolona tablice)
#  Total Cases   : 1,309,728  (Worldometers, zadnji dostupni podatak)
#  Prvi slučaj   : 25. veljače 2020.
# ============================================================
if (!requireNamespace("deSolve", quietly = TRUE)) install.packages("deSolve")
library(deSolve)
# ------------------------------------------------------------
# 1. Parametri modela (zadani u zadatku)
# ------------------------------------------------------------
infection_rate <- 1.02e-07   # beta  – stopa zaraze
recovery_rate  <- 0.2        # gamma – stopa oporavka
# ------------------------------------------------------------
# 2. Populacija i početni uvjeti
# ------------------------------------------------------------
PopSt <- 3826630             # populacija Hrvatske (Worldometers)
S0    <- PopSt - 1
I0    <- 1
R0_ic <- 0                   # R početni uvjet (ne R0!)
state <- c(S = S0, I = I0, R = R0_ic)
# ------------------------------------------------------------
# 3. Broj dana od prvog slučaja do danas
#    Prvi slučaj: 25. veljače 2020.
#    Danas      : 24. travnja 2026.
# ------------------------------------------------------------
datum_prvog_slucaja <- as.Date("2020-02-25")
danas               <- as.Date("2026-04-24")
Time                <- as.integer(danas - datum_prvog_slucaja)
cat("=======================================================\n")
cat(sprintf(" SIR MODEL – COVID-19 u HRVATSKOJ\n"))
cat("=======================================================\n")
cat(sprintf(" Populacija (PopSt)    : %s\n", format(PopSt, big.mark = ".")))
cat(sprintf(" Datum prvog slučaja   : %s\n", datum_prvog_slucaja))
cat(sprintf(" Danas                 : %s\n", danas))
cat(sprintf(" Broj simulacijskih dana (Time) : %d\n", Time))
# ------------------------------------------------------------
# 4. Izračun R0
#    R0 = beta * S0 / gamma
# ------------------------------------------------------------
R0 <- infection_rate * S0 / recovery_rate
cat(sprintf("\n Infection rate (beta) : %.2e\n", infection_rate))
cat(sprintf(" Recovery rate (gamma) : %.2f\n",   recovery_rate))
cat(sprintf(" Osnovni reprodukcijski broj R0 = beta*S0/gamma = %.4f\n\n", R0))
# ------------------------------------------------------------
# 5. Diferencijalne jednadžbe SIR modela
# ------------------------------------------------------------
sir_model <- function(time, state, parameters) {
with(as.list(c(state, parameters)), {
dS <- -beta  * S * I
dI <-  beta  * S * I - gamma * I
dR <-  gamma * I
list(c(dS, dI, dR))
})
}
parameters <- c(beta = infection_rate, gamma = recovery_rate)
# ------------------------------------------------------------
# 6. Numeričko rješavanje ODE
# ------------------------------------------------------------
times    <- seq(0, Time, by = 1)
solution <- as.data.frame(
ode(y = state, times = times, func = sir_model, parms = parameters)
)
# ------------------------------------------------------------
# 7. Usporedba – model vs. stvarni podaci
# ------------------------------------------------------------
total_cases_worldometers <- 1309728   # Worldometers – Total Cases
# Zadnji dan simulacije = danas
zadnji <- tail(solution, 1)
model_I_danas <- zadnji$I
model_R_danas <- zadnji$R
model_IR_danas <- model_I_danas + model_R_danas   # ukupno zaraženi (I+R)
cat("=======================================================\n")
cat(" USPOREDBA – STVARNI PODACI vs. SIR MODEL\n")
cat("=======================================================\n")
cat(sprintf(" Worldometers – Total Cases        : %s\n",
format(round(total_cases_worldometers), big.mark = ".")))
cat(sprintf(" SIR model – I + R za današnji dan : %s\n",
format(round(model_IR_danas), big.mark = ".")))
cat(sprintf("   od toga aktivno zaraženi  (I)   : %s\n",
format(round(model_I_danas), big.mark = ".")))
cat(sprintf("   od toga oporavljeni       (R)   : %s\n",
format(round(model_R_danas), big.mark = ".")))
razlika_pct <- (model_IR_danas - total_cases_worldometers) /
total_cases_worldometers * 100
cat(sprintf("\n Razlika modela od stvarnih podataka: %+.1f%%\n", razlika_pct))
cat("=======================================================\n")
# Vrhunac epidemije
peak_idx <- which.max(solution$I)
peak_day <- solution$time[peak_idx]
peak_I   <- solution$I[peak_idx]
peak_date <- datum_prvog_slucaja + peak_day
cat(sprintf("\n Simulirani vrhunac epidemije:\n"))
cat(sprintf("   Dan %d (%s), zaraženih: %s (%.1f%% populacije)\n\n",
peak_day, peak_date,
format(round(peak_I), big.mark = "."),
peak_I / PopSt * 100))
# ------------------------------------------------------------
# 8. Vizualizacija
# ------------------------------------------------------------
x_axis <- datum_prvog_slucaja + solution$time
# Oznake na x-osi po godinama
x_breaks <- seq(as.Date("2020-01-01"), as.Date("2027-01-01"), by = "year")
x_labels <- format(x_breaks, "%Y")
plot(x_axis, solution$S,
type = "l", col = "steelblue", lwd = 2,
ylim = c(0, PopSt),
xaxt = "n",
xlab = "Datum", ylab = "Broj osoba",
main = sprintf(
"SIR Model – COVID-19 Hrvatska\nbeta=%.2e  |  gamma=%.2f  |  R0=%.4f",
infection_rate, recovery_rate, R0))
axis(1, at = as.numeric(x_breaks), labels = x_labels)
lines(x_axis, solution$I, col = "firebrick",   lwd = 2)
lines(x_axis, solution$R, col = "forestgreen", lwd = 2)
# Vertikalna linija – danas
abline(v = as.numeric(danas), lty = 2, col = "orange", lwd = 1.5)
text(as.numeric(danas), PopSt * 0.95, "danas", col = "orange",
adj = 1.1, cex = 0.85)
# Horizontalna linija – Total Cases (Worldometers)
abline(h = total_cases_worldometers, lty = 3, col = "purple", lwd = 1.5)
text(as.numeric(datum_prvog_slucaja + 30),
total_cases_worldometers + PopSt * 0.02,
sprintf("Worldometers Total Cases: %s",
format(total_cases_worldometers, big.mark = ".")),
col = "purple", adj = 0, cex = 0.8)
legend("right",
legend = c("Osjetljivi (S)", "Zaraženi (I)", "Oporavljeni (R)"),
col    = c("steelblue", "firebrick", "forestgreen"),
lwd    = 2, bty = "n", cex = 0.9)
# ============================================================
#  SIR Model – COVID-19 u Hrvatskoj
#
#  Podaci preuzeti s:
#    https://www.worldometers.info/coronavirus/#countries
#    https://www.worldometers.info/coronavirus/country/croatia/
#
#  Zemlja        : Hrvatska (Croatia)
#  Populacija    : 3,826,630  (Worldometers, zadnja kolona tablice)
#  Total Cases   : 1,309,728  (Worldometers, zadnji dostupni podatak)
#  Prvi slučaj   : 25. veljače 2020.
# ============================================================
if (!requireNamespace("deSolve", quietly = TRUE)) install.packages("deSolve")
library(deSolve)
# ------------------------------------------------------------
# 1. Parametri modela (zadani u zadatku)
# ------------------------------------------------------------
infection_rate <- 1.02e-07   # beta  – stopa zaraze
recovery_rate  <- 0.2        # gamma – stopa oporavka
# ------------------------------------------------------------
# 2. Populacija i početni uvjeti
# ------------------------------------------------------------
PopSt <- 3826630             # populacija Hrvatske (Worldometers)
S0    <- PopSt - 1
I0    <- 1
R0_ic <- 0                   # R početni uvjet (ne R0!)
state <- c(S = S0, I = I0, R = R0_ic)
# ------------------------------------------------------------
# 3. Broj dana od prvog slučaja do danas
#    Prvi slučaj: 25. veljače 2020.
#    Danas      : 24. travnja 2026.
# ------------------------------------------------------------
datum_prvog_slucaja <- as.Date("2020-02-25")
danas               <- as.Date("2021-02-25")
Time                <- as.integer(danas - datum_prvog_slucaja)
cat("=======================================================\n")
cat(sprintf(" SIR MODEL – COVID-19 u HRVATSKOJ\n"))
cat("=======================================================\n")
cat(sprintf(" Populacija (PopSt)    : %s\n", format(PopSt, big.mark = ".")))
cat(sprintf(" Datum prvog slučaja   : %s\n", datum_prvog_slucaja))
cat(sprintf(" Danas                 : %s\n", danas))
cat(sprintf(" Broj simulacijskih dana (Time) : %d\n", Time))
# ------------------------------------------------------------
# 4. Izračun R0
#    R0 = beta * S0 / gamma
# ------------------------------------------------------------
R0 <- infection_rate * S0 / recovery_rate
cat(sprintf("\n Infection rate (beta) : %.2e\n", infection_rate))
cat(sprintf(" Recovery rate (gamma) : %.2f\n",   recovery_rate))
cat(sprintf(" Osnovni reprodukcijski broj R0 = beta*S0/gamma = %.4f\n\n", R0))
# ------------------------------------------------------------
# 5. Diferencijalne jednadžbe SIR modela
# ------------------------------------------------------------
sir_model <- function(time, state, parameters) {
with(as.list(c(state, parameters)), {
dS <- -beta  * S * I
dI <-  beta  * S * I - gamma * I
dR <-  gamma * I
list(c(dS, dI, dR))
})
}
parameters <- c(beta = infection_rate, gamma = recovery_rate)
# ------------------------------------------------------------
# 6. Numeričko rješavanje ODE
# ------------------------------------------------------------
times    <- seq(0, Time, by = 1)
solution <- as.data.frame(
ode(y = state, times = times, func = sir_model, parms = parameters)
)
# ------------------------------------------------------------
# 7. Usporedba – model vs. stvarni podaci
# ------------------------------------------------------------
total_cases_worldometers <- 1309728   # Worldometers – Total Cases
# Zadnji dan simulacije = danas
zadnji <- tail(solution, 1)
model_I_danas <- zadnji$I
model_R_danas <- zadnji$R
model_IR_danas <- model_I_danas + model_R_danas   # ukupno zaraženi (I+R)
cat("=======================================================\n")
cat(" USPOREDBA – STVARNI PODACI vs. SIR MODEL\n")
cat("=======================================================\n")
cat(sprintf(" Worldometers – Total Cases        : %s\n",
format(round(total_cases_worldometers), big.mark = ".")))
cat(sprintf(" SIR model – I + R za današnji dan : %s\n",
format(round(model_IR_danas), big.mark = ".")))
cat(sprintf("   od toga aktivno zaraženi  (I)   : %s\n",
format(round(model_I_danas), big.mark = ".")))
cat(sprintf("   od toga oporavljeni       (R)   : %s\n",
format(round(model_R_danas), big.mark = ".")))
razlika_pct <- (model_IR_danas - total_cases_worldometers) /
total_cases_worldometers * 100
cat(sprintf("\n Razlika modela od stvarnih podataka: %+.1f%%\n", razlika_pct))
cat("=======================================================\n")
# Vrhunac epidemije
peak_idx <- which.max(solution$I)
peak_day <- solution$time[peak_idx]
peak_I   <- solution$I[peak_idx]
peak_date <- datum_prvog_slucaja + peak_day
cat(sprintf("\n Simulirani vrhunac epidemije:\n"))
cat(sprintf("   Dan %d (%s), zaraženih: %s (%.1f%% populacije)\n\n",
peak_day, peak_date,
format(round(peak_I), big.mark = "."),
peak_I / PopSt * 100))
# ------------------------------------------------------------
# 8. Vizualizacija
# ------------------------------------------------------------
x_axis <- datum_prvog_slucaja + solution$time
# Oznake na x-osi po godinama
x_breaks <- seq(as.Date("2020-01-01"), as.Date("2027-01-01"), by = "year")
x_labels <- format(x_breaks, "%Y")
plot(x_axis, solution$S,
type = "l", col = "steelblue", lwd = 2,
ylim = c(0, PopSt),
xaxt = "n",
xlab = "Datum", ylab = "Broj osoba",
main = sprintf(
"SIR Model – COVID-19 Hrvatska\nbeta=%.2e  |  gamma=%.2f  |  R0=%.4f",
infection_rate, recovery_rate, R0))
axis(1, at = as.numeric(x_breaks), labels = x_labels)
lines(x_axis, solution$I, col = "firebrick",   lwd = 2)
lines(x_axis, solution$R, col = "forestgreen", lwd = 2)
# Vertikalna linija – danas
abline(v = as.numeric(danas), lty = 2, col = "orange", lwd = 1.5)
text(as.numeric(danas), PopSt * 0.95, "danas", col = "orange",
adj = 1.1, cex = 0.85)
# Horizontalna linija – Total Cases (Worldometers)
abline(h = total_cases_worldometers, lty = 3, col = "purple", lwd = 1.5)
text(as.numeric(datum_prvog_slucaja + 30),
total_cases_worldometers + PopSt * 0.02,
sprintf("Worldometers Total Cases: %s",
format(total_cases_worldometers, big.mark = ".")),
col = "purple", adj = 0, cex = 0.8)
legend("right",
legend = c("Osjetljivi (S)", "Zaraženi (I)", "Oporavljeni (R)"),
col    = c("steelblue", "firebrick", "forestgreen"),
lwd    = 2, bty = "n", cex = 0.9)
library(shiny); runApp('Documents/ModSim-projekt/Untitled.R')
runApp('Documents/ModSim-projekt/Untitled.R')
